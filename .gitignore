.DS_Store
.claude/
.tmp/
*.zip
# ...except the published theme build artefacts.
!wordpress-theme/*.zip

# FUSE filesystem leftover temp files (unlinked-while-open marker files)
.fuse_hidden*

# Python bytecode cache
__pycache__/
*.pyc

# Podcast audio source files — large binaries, kept locally only
/assets/podcasts/**/*.mp3
/assets/podcasts/**/*.wav
/assets/podcasts/**/*.m4a
/assets/podcasts/**/*.flac

# Whisper.cpp model files — large binaries, downloadable from huggingface
/assets/podcasts/whisper-models/

# Whisper raw SRT output (intermediate; the parsed .md is what we keep in git)
/assets/podcasts/**/transcripts/*.srt
/assets/podcasts/**/transcripts/*.raw
/assets/podcasts/**/transcripts/*.json

# Video source files — pending YouTube upload, kept locally only
/assets/videos/**/*.mp4
/assets/videos/**/*.mov

# Image originals destined for the WP media library — re-downloadable via
# scripts/download-images.sh; optimized/ subdir is regenerated by
# scripts/optimize-assets.sh.
# (theme assets at wordpress-theme/**/assets/ are NOT anchored to root, so they stay tracked.)
/assets/images/
