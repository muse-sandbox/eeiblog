.DS_Store
.claude/
.tmp/
*.zip

# Podcast / video / audio source files — large binaries, kept locally only
media/**/*.mp3
media/**/*.wav
media/**/*.m4a
media/**/*.mp4
media/**/*.mov
media/**/*.flac

# Image source dumps from Squarespace CDN — re-downloadable from the proxy
media/images/squarespace-cdn/

# Image originals destined for the WP media library — re-downloadable via
# scripts/download-images.sh; optimized/ subdir is regenerated by
# scripts/optimize-assets.sh.
assets/

# Hero/logo images cached at repo root — already in WP media, kept locally only.
# (wordpress-theme/**/screenshot.png is in a subdir and stays tracked.)
/*.webp

# Whisper.cpp model files — large binaries, downloadable from huggingface
media/whisper-models/

# Whisper raw SRT output (intermediate; the parsed .md is what we keep in git)
media/podcasts/**/transcripts/*.srt
media/podcasts/**/transcripts/*.raw
media/podcasts/**/transcripts/*.json
